      "source_ref": "day_04.ep13.drama"
    },
    {
      "id": "ep013_s02",
      "kind": "dialogue",
      "is_chat": false,
      "location": "Зеркальный Город, тупик с зеркалом-порталом",
      "time": "вне времени",
      "chars": [
        "Марко",
        "Мама"
      ],
      "mood": "слова брешуть, тіло — ні",
      "branch_type": null,
      "set_flags": [],
