      "text": [
        {
          "who": "Автор",
          "line": "Марко блукає. Після Леона, після Віри, після числа 40 — ноги йдуть самі. Провулки Дзеркального Міста однакові, як копії однієї сторінки. Дзеркала на стінах — але Марко більше не дивиться в них. Досить відображень."
        },
        {
          "who": "Автор",
          "line": "Глухий кут. Стіна попереду, стіни по боках. І — дзеркало. Велике, на весь зріст. Але в ньому — не провулок."
        },
        {
          "who": "Автор",
          "line": "Кухня."
        },
        {
          "who": "Автор",
          "line": "Їхня кухня. Жовті фіранки з соняшниками. Холодильник із магнітами з Одеси. Марко знає кожен сантиметр."
        },
        {
          "who": "Автор",
          "line": "За столом — мама."
        }
      ],
      "quizzes": [],
      "choice": {
        "question": "Що робить Марко?",
        "options": [
          {
            "id": "approach",
            "text": "Підійти до дзеркала",
