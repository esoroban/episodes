    {
      "id": "ep013_s04",
      "kind": "narrative",
      "is_chat": false,
      "location": "Зеркальный Город, тупик с зеркалом-порталом",
      "time": "вне времени",
      "chars": [
        "Марко"
      ],
      "mood": "ім'я — для того, що вже побачено",
