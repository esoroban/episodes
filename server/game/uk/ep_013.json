      "text": [
        {
          "who": "Автор",
          "line": "Чашка в руках. Чай. Пара здіймається — але мама не п'є. Руки стискають чашку так, що кісточки побіліли."
        },
        {
          "who": "Марко",
          "line": "Мамо?"
        },
        {
          "who": "Автор",
          "line": "Вона здригається. Дивиться — не на Марка. На двері. Потім — у дзеркало. Бачить його."
        },
        {
          "who": "Мама",
          "line": "Марку. У мене все добре. Не хвилюйся."
        },
        {
          "who": "Автор",
          "line": "Усмішка. Але не до очей. Як фотографія — все на місці, але щось неживе. Мама каже «добре» — а руки тремтять. Каже «не хвилюйся» — а очі бігають до дверей. Кого вона чекає?"
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
      "visual_brief": {
        "background": "Зеркало-портал, кухня внутри. Мама за столом",
