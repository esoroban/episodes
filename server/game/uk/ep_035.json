      "text": [
        {
          "who": "Автор",
          "line": "Ліна дістає блокнот. Маленький, потертий. Обкладинка — сіра. Сторінки — охайні, дрібний почерк. Стовпці: дата, місце, що сказав Марко, кому довіряв."
        },
        {
          "who": "Автор",
          "line": "Марко бере блокнот. Руки не тремтять — вони дерев'яні."
        },
        {
          "who": "Автор",
          "line": "Сторінка перша: день знайомства. «Марко — відкритий. Погоджується легко. Довіряє швидко.»"
        },
        {
          "who": "Автор",
          "line": "Сторінка десята: «Розповів про Софу. Показав екран. Не перевірив, хто поряд.»"
        },
        {
          "who": "Автор",
          "line": "Остання сторінка: «Він довіряє мені цілковито.»"
        },
        {
          "who": "Автор",
          "line": "Блокнот падає на підлогу. Звук — глухий."
        },
        {
          "who": "Сем",
          "line": "Вона шпигунка!"
        },
        {
          "who": "Автор",
          "line": "Марко мовчить. Ноги не тримають. Ліна — єдина, кому він довіряв після всього. Довіра була — пасткою?"
        },
        {
          "who": "Автор",
          "line": "Удар у сонячне сплетіння. Кожна сторінка — доказ: тебе вивчали."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
