      "text": [
        {
          "who": "Автор",
          "line": "Десятки сірих ниток. Светр Ліни — як павутина. Кожна нитка — контакт із Системою. Кожна — звіт."
        },
        {
          "who": "Автор",
          "line": "Ліна не відступає. Не опускає очей. Стоїть — рівно, як на суді."
        },
        {
          "who": "Ліна",
          "line": "Так. Десятки. Кожна — контакт. Кожна — звіт."
        }
      ],
      "quizzes": [],
