      "text": [
        {
          "who": "Автор",
          "line": "Марко пише записку. Вугільним олівцем на клаптику тканини. Для тих, кого ще не стерто. Для спротиву."
        },
        {
          "who": "Автор",
          "line": "«Я бачив, як стирають людей. Місто не таке, яким здається.»"
        },
        {
          "who": "Автор",
          "line": "Передає ланцюжком. Сем — дівчинці з косою. Дівчинка — хлопчику із синцем на коліні. Хлопчик — далі."
        },
        {
          "who": "Автор",
          "line": "Правда — з рук у руки, як записка на уроці."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
