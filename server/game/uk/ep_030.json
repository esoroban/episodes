      "text": [
        {
          "who": "Автор",
          "line": "Надвечір — динаміки. Голос Рея."
        },
        {
          "who": "Рей",
          "line": "Марко ЗІЗНАВСЯ. Він БАЧИВ стирання. І НІЧОГО НЕ ЗРОБИВ."
        },
        {
          "who": "Рей",
          "line": "Він стояв і дивився, як стирають людину. Не допоміг. Не закричав. Стояв."
        },
        {
          "who": "Автор",
          "line": "Марко зупиняється. Слова — його. Справжні. Він справді бачив."
        },
        {
          "who": "Автор",
          "line": "Але половина — відрізана. І від цієї половини — він став іншою людиною. Тим, хто стояв, а не тим, хто намагався."
        },
        {
          "who": "Автор",
          "line": "Правда стала зброєю. Слова справжні — але ранять як брехня."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
