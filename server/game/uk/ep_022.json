      "text": [
        {
          "who": "Автор",
          "line": "Ліва колонка — «Що він сказав». Права — «Що він зробив»."
        },
        {
          "who": "Автор",
          "line": "«Я даю свободу» — замкнув двері."
        },
        {
          "who": "Автор",
          "line": "«Я не стираю — я захищаю» — Леон стертий."
        },
        {
          "who": "Автор",
          "line": "«Кожен голос важливий» — незгодних прибирають."
        },
        {
          "who": "Автор",
          "line": "«Я дбаю про дітей» — числа падають."
        },
        {
          "who": "Автор",
          "line": "«Місто — місце безпеки» — Макс стирається."
        },
        {
          "who": "Автор",
          "line": "Десятки рядків. Кожен — тріщина. Окремо — дрібниця. Разом — стіна валиться."
        },
        {
          "who": "Автор",
          "line": "Софія збирала докази. Місяцями. Кожну суперечність — зафіксовано."
        }
      ],
      "quizzes": [],
