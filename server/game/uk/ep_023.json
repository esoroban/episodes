      "text": [
        {
          "who": "Автор",
          "line": "Марко робить крок уперед. Горло палає. Хочеться крикнути «неправда»."
        },
        {
          "who": "Автор",
          "line": "Макс — не обертаючись — підіймає руку. Долоня відкрита. Назад."
        },
        {
          "who": "Автор",
          "line": "«Не зараз, Марку. Їм слова потрібні, не кулаки.»"
        },
        {
          "who": "Автор",
          "line": "Марко зупиняється. Руку стискає в кулак. Потім розтискає. Не кулаки. Слова. Слова лікують і слова стирають. Він повертається на крок."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
