      "text": [
        {
          "who": "Автор",
          "line": "Вулиця за площею. Марко веде Макса в підпілля. Швидко. Тихо."
        },
        {
          "who": "Автор",
          "line": "Не встигають."
        },
        {
          "who": "Автор",
          "line": "Троє агентів. Сірий одяг. Числа високі — 80, 85, 90. Лояльні. Слухняні. Очі — ясні, але порожні. Наче вітрини."
        },
        {
          "who": "Автор",
          "line": "Макс стає між ними і Марком. Кулаки стиснуті."
        },
        {
          "who": "Автор",
          "line": "Агенти не б'ються. Говорять."
        }
      ],
