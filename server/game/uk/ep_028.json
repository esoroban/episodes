      "text": [
        {
          "who": "Автор",
          "line": "Марко показує зошит Семові. «Тато сказав.» «Тато сказав.» «Тато сказав.» Двадцять років одного й того самого."
        },
        {
          "who": "Сем",
          "line": "Якщо тато Віри — той, хто керує Містом… а її відправили до нашої школи… отже, Віра досі в нього в полоні?"
        },
        {
          "who": "Автор",
          "line": "Тиша. Динаміки на стінах мовчать. Дзеркала — темні."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
