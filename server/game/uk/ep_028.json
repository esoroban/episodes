      "text": [
        {
          "who": "Голос",
          "line": "А ти взагалі загубився. Тобі б додому, а не гратися в детектива."
        },
        {
          "who": "Автор",
          "line": "Сем стискається. Очі — мокрі."
        },
        {
          "who": "Автор",
          "line": "Голос не відповів на питання Сема. Не сказав — так, Віра в полоні, чи ні. Не навів фактів. Не використав логіку. Не дав обґрунтування."
        },
        {
          "who": "Автор",
          "line": "Натомість — ударив по ЛЮДИНІ."
        }
      ],
      "quizzes": [],
      "choice": {
        "question": "Що робить Марко?",
