      "text": [
        {
          "who": "Автор",
          "line": "Потім — Голос. Не з динаміків. Не з дзеркал. Просто в голові Марка. Теплий. Батьківський. Як колискова."
        },
        {
          "who": "Голос",
          "line": "Ти маленький. Ти нічого не розумієш. Спершу виростай — потім сперечайся."
        },
        {
          "who": "Автор",
          "line": "Марко здригається. Слова влучають туди, де живе сумнів. «Маленький.» Слово — як палець, що тисне на синець."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
      "visual_brief": {
        "background": "Центральная площадь, Марко в центре, вокруг — лёгкая дымка, зеркальные стены отражают только его",
        "camera": "close-up",
        "characters": [
          {
            "who": "Марко",
            "expression": "вздрогнул, лицо напряглось",
            "pose": "стоит неподвижно, рука с телефоном опустилась",
            "position": "center"
          }
        ],
        "props": [
          "зеркальные стены",
          "отражения Марко в нескольких зеркалах сразу"
