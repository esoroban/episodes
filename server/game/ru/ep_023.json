      "text": [
        {
          "who": "author",
          "line": "Улица за площадью. Марко ведёт Макса в подполье. Быстро. Тихо."
        },
        {
          "who": "author",
          "line": "Не успевают."
        },
        {
          "who": "author",
          "line": "Трое агентов. Серая одежда. Числа высокие — 80, 85, 90. Лояльные. Послушные. Глаза — ясные, но пустые. Как витрины."
        },
        {
          "who": "author",
          "line": "Макс встаёт между ними и Марко. Кулаки сжаты."
        },
        {
          "who": "author",
          "line": "Агенты не дерутся. Говорят."
        }
      ],
