      "text": [
        {
          "who": "author",
          "line": "Потом — Голос. Не из динамиков. Не из зеркал. Прямо в голове Марко. Тёплый. Отцовский. Как колыбельная."
        },
        {
          "who": "Голос",
          "line": "Ты маленький. Ты ничего не понимаешь. Сначала вырасти — потом спорь."
        },
        {
          "who": "author",
          "line": "Марко вздрагивает. Слова попадают туда, где живёт сомнение. «Маленький.» Слово — как палец, который давит на синяк."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
      "visual_brief": {
        "background": "Центральная площадь, Марко в центре, вокруг — лёгкая дымка, зеркальные стены отражают только его",
        "camera": "close-up",
        "characters": [
          {
            "who": "Марко",
            "expression": "вздрогнул, лицо напряглось",
