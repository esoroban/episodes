      "text": [
        {
          "who": "author",
          "line": "Марко показывает файл Сему. «Папа сказал.» «Папа сказал.» «Папа сказал.» Двадцать лет одного и того же."
        },
        {
          "who": "Сем",
          "line": "Если папа Веры — тот, кто управляет Городом… значит, Вера тоже пленница?"
        },
        {
          "who": "author",
          "line": "Тишина. Динамики на стенах молчат. Зеркала — тёмные."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
