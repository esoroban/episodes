      "text": [
        {
          "who": "author",
          "line": "Число на стене: 26. Марко не прикасался к артефактам. Не открывал порталы. Не трогал зеркала. А число упало."
        },
        {
          "who": "author",
          "line": "Стирание ускоряется. Без причины. Без контакта."
        },
        {
          "who": "author",
          "line": "Марко рисует на стене подполья. Уголь. Схема. Цепочка."
        },
        {
          "who": "author",
          "line": "Вера → школьный журнал → данные о Софии → Голос → стирание."
        },
        {
          "who": "author",
          "line": "Каждое звено — проверяемо. Вера имеет доступ к журналу. Журнал содержит данные. Голос использует данные для стирания."
        },
        {
          "who": "author",
          "line": "Кроме одного звена: ЗАЧЕМ Вере помогать Голосу?"
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
