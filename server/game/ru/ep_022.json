      "text": [
        {
          "who": "author",
          "line": "Левая колонка — «Что он сказал». Правая — «Что он сделал»."
        },
        {
          "who": "author",
          "line": "«Я даю свободу» — запер двери."
        },
        {
          "who": "author",
          "line": "«Я не стираю — я защищаю» — Леон стёрт."
        },
        {
          "who": "author",
          "line": "«Каждый голос важен» — несогласных убирают."
        },
        {
          "who": "author",
          "line": "«Я забочусь о детях» — числа падают."
        },
        {
          "who": "author",
          "line": "«Город — место безопасности» — Макс стирается."
        },
        {
          "who": "author",
          "line": "Десятки строк. Каждая — трещина. По отдельности — мелочь. Вместе — стена рушится."
        },
        {
          "who": "author",
          "line": "София собирала доказательства. Месяцами. Каждое противоречие — зафиксировано."
        }
      ],
      "quizzes": [],
      "choice": {
        "question": "Что делает Марко?",
