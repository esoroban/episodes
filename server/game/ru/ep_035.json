      "text": [
        {
          "who": "author",
          "line": "Десятки серых ниток. Свитер Лины — как паутина. Каждая нитка — контакт с Системой. Каждая — отчёт."
        },
        {
          "who": "author",
          "line": "Лина не отступает. Не опускает глаза. Стоит — прямо, как на суде."
        },
        {
          "who": "Лина",
          "line": "Да. Десятки. Каждая — контакт. Каждая — отчёт."
        }
      ],
      "quizzes": [],
      "choice": null,
      "unlock": null,
